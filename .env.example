# ============================================
# 医学信息收集系统 - 环境变量配置模板
# Medical Information Collection System - ENV Template
# ============================================
# 使用说明：
# 1. 复制此文件为 .env：cp .env.example .env
# 2. 填写实际的配置值
# 3. .env 文件不会被提交到 Git 仓库

# ============================================
# PubMed API 配置
# ============================================
# 申请地址: https://www.ncbi.nlm.nih.gov/account/
PUBMED_API_KEY=your_pubmed_api_key_here

# ============================================
# 百度翻译 API 配置
# ============================================
# 申请地址: https://fanyi-api.baidu.com/
BAIDU_TRANSLATE_APP_ID=your_baidu_app_id_here
BAIDU_TRANSLATE_APP_KEY=your_baidu_app_key_here

# ============================================
# 翻译服务提供商选择
# ============================================
# 可选值: auto (优先百度), baidu (仅百度), helsinki (仅开源模型)
TRANSLATION_PROVIDER=auto

# ============================================
# 代理配置
# ============================================
# 是否启用代理 (true/false)
USE_PROXY=false

# ============================================
# 系统配置
# ============================================
# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
