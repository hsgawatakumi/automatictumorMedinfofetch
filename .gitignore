# ============================================
# 基因药物知识库 - .gitignore
# Gene Drug Knowledge Base
# ============================================

# --- Node.js / npm ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
npm-shrinkwrap.json
package-lock.json.bak

# --- Node.js runtime ---
pids
*.pid
*.seed
*.pid.lock
lib-cov/
coverage/
.nyc_output/

# --- Dependency directories ---
jspm_packages/
bower_components/

# --- TypeScript ---
*.ts.build.log
cache/
.parcel-cache/

# --- Optional npm cache ---
.npm

# --- Optional eslint cache ---
.eslintcache

# --- Yarn ---
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Runtime data files ---
*.log
*.db
*.sqlite
*.sqlite3

# --- Application data ---
data/
exports/
# 注意: 不使用 *.json 以避免忽略 package.json、nixpacks.toml 等配置文件
# 特定数据文件在 data/ 子目录下会被自动忽略

# --- System files ---
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
System Volume Information

# --- Editor / IDE files ---
.idea/
.vscode/
*.swp
*.swo
*~

# --- Environment variables (sensitive) ---
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging

# --- Railway specific ---
.railway/
railway.toml
.railwayapp/

# --- Lock files ---
package-lock.json
yarn.lock
pnpm-lock.yaml

# --- Test files / output ---
test-output/
*.test.js.snap
coverage/

# --- CI / Build output ---
build/
dist/
out/
.cache/

# --- Python leftovers (in case any exist) ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# --- Temp / backup ---
*.tmp
*.bak
*.old
*.orig
